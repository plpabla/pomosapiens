---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import type { Database } from "@/db/database.types";
import { Card } from "@/components/ui/card";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);

type SessionRow = Database["public"]["Tables"]["sessions"]["Row"];

const FOCUS_PRESET_SECONDS = 25 * 60;
const ABANDONED_THRESHOLD_MS = 2 * FOCUS_PRESET_SECONDS * 1000;

let sessions: Pick<
  SessionRow,
  "id" | "started_at" | "energy_level" | "duration_seconds" | "focus_rating" | "ended_at"
>[] = [];
let dbError: string | null = null;

if (!supabase) {
  dbError = "Supabase is not configured. Set SUPABASE_URL and SUPABASE_KEY.";
} else if (!user) {
  dbError = "Not authenticated.";
} else {
  const { data, error } = await supabase
    .from("sessions")
    .select("id, started_at, energy_level, duration_seconds, focus_rating, ended_at")
    .eq("user_id", user.id)
    .order("started_at", { ascending: false })
    .limit(50);
  if (error) {
    dbError = error.message;
  } else {
    sessions = data;
  }
}

function formatDate(iso: string) {
  return new Intl.DateTimeFormat("en-GB", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
    hour: "2-digit",
    minute: "2-digit",
    hour12: false,
  }).format(new Date(iso));
}

function formatDuration(seconds: number) {
  const m = Math.floor(seconds / 60);
  const s = seconds % 60;
  return `${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")}`;
}

function getStatus(session: { ended_at: string | null; started_at: string }) {
  if (session.ended_at !== null) return "done";
  const ageMs = Date.now() - new Date(session.started_at).getTime();
  return ageMs <= ABANDONED_THRESHOLD_MS ? "in_progress" : "abandoned";
}

const energyColorClass: Record<string, string> = {
  high: "text-spark",
  medium: "text-blaze",
  low: "text-ash",
};
---

<Layout title="Dashboard">
  <div class="bg-cosmic min-h-screen p-4">
    <div class="mx-auto max-w-2xl">
      <div class="mb-8">
        <a
          href="/session/new"
          class="bg-blaze hover:bg-spark text-off-white inline-flex items-center justify-center rounded-lg px-8 py-3 text-base font-semibold transition-colors"
        >
          Start session
        </a>
      </div>

      <h2 class="text-off-white mb-4 text-xl font-semibold">History</h2>

      {
        dbError && (
          <div class="border-spark/40 bg-crimson/40 text-spark rounded-lg border px-4 py-3 text-sm">{dbError}</div>
        )
      }

      {
        !dbError && sessions.length === 0 && (
          <Card className="border-charred bg-transparent p-6 shadow-none text-center">
            <p class="text-ash text-sm">No sessions yet. Start your first one above.</p>
          </Card>
        )
      }

      {
        !dbError && sessions.length > 0 && (
          <ul class="space-y-3">
            {sessions.map((session) => {
              const status = getStatus(session);
              const energyClass = energyColorClass[session.energy_level] ?? "text-ash";
              return (
                <li>
                  <Card className="border-charred bg-ember text-off-white gap-2 px-5 py-4 shadow-none">
                    <div class="flex items-center justify-between">
                      <span class="text-off-white/70 text-sm">{formatDate(session.started_at)}</span>
                      <span class:list={["text-xs font-semibold uppercase", energyClass]}>{session.energy_level}</span>
                    </div>
                    <div class="flex items-center justify-between">
                      <span class="text-off-white text-sm">
                        {status === "done" && session.duration_seconds != null
                          ? formatDuration(session.duration_seconds)
                          : status === "in_progress"
                            ? "In progress"
                            : "Abandoned"}
                      </span>
                      <span class="text-off-white/80 text-sm">
                        {status === "done"
                          ? session.focus_rating != null
                            ? `★ ${session.focus_rating} / 5`
                            : "Skipped"
                          : ""}
                      </span>
                    </div>
                  </Card>
                </li>
              );
            })}
          </ul>
        )
      }
    </div>
  </div>
</Layout>
