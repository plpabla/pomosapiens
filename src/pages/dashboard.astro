---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import FocusRatingChart from "@/components/dashboard/FocusRatingChart";
import SessionList from "@/components/session/SessionList";
import { isRated } from "@/lib/session/format";
import type { SessionListItem } from "@/lib/types";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);

let sessions: SessionListItem[] = [];
let dbError: string | null = null;

if (!supabase) {
  dbError = "Supabase is not configured. Set SUPABASE_URL and SUPABASE_KEY.";
} else if (!user) {
  dbError = "Not authenticated.";
} else {
  const { data, error } = await supabase
    .from("sessions")
    .select(
      "id, started_at, energy_level, duration_seconds, focus_rating, ended_at, timer_mode, note, topic_id, material_format_id, topic:topics(name), material_format:material_formats(name)",
    )
    .eq("user_id", user.id)
    .order("started_at", { ascending: false })
    .limit(50);
  if (error) {
    dbError = error.message;
  } else {
    sessions = data;
  }
}

const ratedSessions = sessions
  .filter(isRated)
  .map((s) => ({ started_at: s.started_at, focus_rating: s.focus_rating }))
  .reverse();
---

<Layout title="Dashboard">
  <div class="bg-cosmic flex-1 p-4">
    <div class="mx-auto max-w-2xl">
      <div class="mb-8 flex items-center gap-4">
        <a
          href="/session/new"
          class="bg-blaze hover:bg-spark text-off-white inline-flex items-center justify-center rounded-lg px-8 py-3 text-base font-semibold transition-colors"
        >
          Start session
        </a>
        <a href="/presets" class="text-ash hover:text-off-white text-sm transition-colors">Manage presets</a>
      </div>

      <h2 class="text-off-white mb-4 text-xl font-semibold">History</h2>

      <div class="mb-6">
        <FocusRatingChart sessions={ratedSessions} client:only="react" />
      </div>

      <SessionList sessions={sessions} error={dbError} client:load />
    </div>
  </div>
</Layout>
