---
import Layout from "@/layouts/Layout.astro";

const { user } = Astro.locals;
---

<Layout title="Dashboard">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="border-charred bg-ember text-off-white rounded-2xl border p-8 text-center backdrop-blur-xl">
      <h1 class="from-off-white to-blaze mb-4 bg-gradient-to-r bg-clip-text text-3xl font-bold text-transparent">
        Dashboard
      </h1>
      <p class="text-off-white/80">
        Welcome, <span class="text-off-white font-semibold">{user?.email}</span>
      </p>
      <p class="text-ash mt-2 text-sm">This page is only for authenticated users.</p>
      <form method="POST" action="/api/auth/signout" class="mt-6">
        <button
          type="submit"
          class="border-charred bg-charred hover:bg-crimson rounded-lg border px-4 py-2 text-sm transition-colors"
        >
          Sign out
        </button>
      </form>
    </div>
  </div>
</Layout>
