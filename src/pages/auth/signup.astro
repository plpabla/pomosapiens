---
import Layout from "@/layouts/Layout.astro";
import SignUpForm from "@/components/auth/SignUpForm";

const error = Astro.url.searchParams.get("error");
---

<Layout title="Sign up">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="border-charred bg-ember text-off-white w-full max-w-sm rounded-2xl border p-8 backdrop-blur-xl">
      <h1
        class="from-off-white to-blaze mb-6 bg-gradient-to-r bg-clip-text text-center text-2xl font-bold text-transparent"
      >
        Sign up
      </h1>
      <SignUpForm serverError={error} client:load />
      <p class="text-ash mt-4 text-center text-sm">
        Already have an account? <a href="/auth/signin" class="text-blaze hover:underline">Sign in</a>
      </p>
    </div>
  </div>
</Layout>
