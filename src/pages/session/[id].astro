---
import Layout from "@/layouts/Layout.astro";
import SessionRunner from "@/components/session/SessionRunner";
import { createClient } from "@/lib/supabase";
import { resolveSessionPageAccess } from "@/lib/session/access";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/dashboard");
}

const supabase = createClient(Astro.request.headers, Astro.cookies);
if (!supabase) {
  return Astro.redirect("/dashboard");
}

const { user } = Astro.locals;
if (!user) {
  return Astro.redirect("/auth/signin");
}

const { data, error } = await supabase
  .from("sessions")
  .select("id, started_at, ended_at, energy_level, planned_focus_seconds, planned_break_seconds, timer_mode")
  .eq("id", id)
  .eq("user_id", user.id)
  .maybeSingle();

if (error) {
  return Astro.redirect("/dashboard");
}

const access = resolveSessionPageAccess({ row: data });

if (access.kind === "redirect") {
  return Astro.redirect(access.to);
}

// Type narrowing only -- null is redirected above via resolveSessionPageAccess
if (!data) return Astro.redirect("/dashboard");

const { startedAtMs } = access;
const focusSeconds = data.planned_focus_seconds ?? 25 * 60;
const mode = data.timer_mode === "count_up" ? "count_up" : "preset";
const breakSeconds = mode === "count_up" ? null : (data.planned_break_seconds ?? 0);
---

<Layout title="Session">
  <div class="bg-cosmic flex flex-1 flex-col items-center justify-center">
    <SessionRunner
      sessionId={data.id}
      startedAtMs={startedAtMs}
      focusSeconds={focusSeconds}
      mode={mode}
      breakSeconds={breakSeconds}
      fullHeight={false}
      client:load
    />
  </div>
</Layout>
