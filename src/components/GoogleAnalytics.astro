---
interface Props {
  measurementId: string;
}

const { measurementId } = Astro.props;
---

<script async is:inline src={`https://www.googletagmanager.com/gtag/js?id=${measurementId}`}></script>
<script is:inline define:vars={{ gaId: measurementId }}>
  window.dataLayer = window.dataLayer || [];
  function gtag() {
    dataLayer.push(arguments);
  }
  gtag("js", new Date());
  gtag("config", gaId);
</script>
