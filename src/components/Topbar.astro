---
import { Image } from "astro:assets";
import iconImage from "@/assets/icon.png";

const { user } = Astro.locals;
---

<div
  class="border-charred bg-ember text-off-white/80 mb-4 flex items-center justify-between rounded-xl border px-4 py-2 text-sm"
>
  {
    user ? (
      <>
        <div class="flex items-center gap-2">
          <Image src={iconImage} alt="PomoSapiens" width={28} height={28} class="rounded" />
          <span class="text-ash">{user.email}</span>
        </div>
        <div class="flex items-center gap-3">
          <a href="/dashboard" class="text-blaze hover:text-spark transition-colors hover:underline">
            {" "}
            Dashboard{" "}
          </a>
          <a href="/topics" class="text-blaze hover:text-spark transition-colors hover:underline">
            {" "}
            Topics{" "}
          </a>
          <a href="/formats" class="text-blaze hover:text-spark transition-colors hover:underline">
            {" "}
            Formats{" "}
          </a>
          <form method="POST" action="/api/auth/signout">
            <button type="submit" class="text-blaze hover:text-spark transition-colors hover:underline">
              Sign out
            </button>
          </form>
        </div>
      </>
    ) : (
      <>
        <div class="flex items-center gap-2">
          <Image src={iconImage} alt="PomoSapiens" width={28} height={28} class="rounded" />
          <span class="text-ash">Not signed in</span>
        </div>
        <div class="flex gap-3">
          <a href="/auth/signin" class="text-blaze hover:text-spark transition-colors hover:underline">
            {" "}
            Sign in{" "}
          </a>
          <a href="/auth/signup" class="text-blaze hover:text-spark transition-colors hover:underline">
            {" "}
            Sign up{" "}
          </a>
        </div>
      </>
    )
  }
</div>
