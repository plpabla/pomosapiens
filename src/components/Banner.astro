---
type Variant = "info" | "warning" | "error";

interface Props {
  variant?: Variant;
}

const { variant = "info" } = Astro.props;
---

<div class:list={["banner", `banner--${variant}`]} role={variant === "error" ? "alert" : "status"}>
  <slot />
</div>

<style>
  .banner {
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    text-align: center;
    border-bottom: 1px solid;
  }
  .banner :global(a) {
    color: inherit;
    text-decoration: underline;
    font-weight: 600;
  }
  .banner--info {
    background: #1a0a08;
    color: #f5f0eb;
    border-color: #2d5a1b;
  }
  .banner--warning {
    background: #1a0a08;
    color: #f5f0eb;
    border-color: #e8320a;
  }
  .banner--error {
    background: #4a2020;
    color: #f5f0eb;
    border-color: #ff5722;
  }
</style>
